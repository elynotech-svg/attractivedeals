    }
  ],
  "filters": {
    "min_discount_percent": 25,
    "min_savings_amount": 100,
    "require_discount_data": true,
    "blocked_keywords": [
      "refurbished",
      "used",
      "renewed",
      "expired",
      "out of stock"
    ],
    "required_keywords": [],
    "max_items": 10
  },
  "hashtags": [
    "#deals",
    "#offers",
    "#shopping",
    "#affiliate"
  ],
  "telegram": {
    "enabled": true,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_id_env": "TELEGRAM_CHAT_ID",
    "disable_web_page_preview": false,
    "timeout_seconds": 15,
    "required": false
  },
  "whatsapp": {
    "output_file": "out/whatsapp_deals.txt"
  }
}
