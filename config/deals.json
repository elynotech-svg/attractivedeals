{
  "_notes": [
    "Affiliate feed/API URLs for these merchants are account-specific and usually come from the merchant partner dashboard or an affiliate network such as Cuelinks, Admitad, Impact, vCommission, or EarnKaro.",
    "Set the *_FEED_URL environment variables below to your real approved feed URLs before running. Optional *_AUTH_HEADER and *_API_KEY variables are sent as request headers when set.",
    "Amazon India PA-API is a signed POST API, not a simple feed URL. Use an approved feed/export URL or a small PA-API proxy that returns JSON/RSS for this workflow."
  ],
  "feeds": [
    {
      "name": "amazon-india",
      "enabled": true,
      "url": "${AMAZON_IN_FEED_URL:-}",
      "type": "auto",
      "headers": {
        "Authorization": "${AMAZON_IN_AUTH_HEADER:-}",
        "x-api-key": "${AMAZON_IN_API_KEY:-}"
      },
      "items_path": "${AMAZON_IN_ITEMS_PATH:-}",
      "title_field": "${AMAZON_IN_TITLE_FIELD:-title}",
      "url_field": "${AMAZON_IN_URL_FIELD:-affiliate_url}",
      "price_field": "${AMAZON_IN_PRICE_FIELD:-price}",
      "original_price_field": "${AMAZON_IN_ORIGINAL_PRICE_FIELD:-original_price}",
      "discount_percent_field": "${AMAZON_IN_DISCOUNT_PERCENT_FIELD:-discount_percent}",
      "coupon_field": "${AMAZON_IN_COUPON_FIELD:-coupon}",
      "category_field": "${AMAZON_IN_CATEGORY_FIELD:-category}",
      "description_field": "${AMAZON_IN_DESCRIPTION_FIELD:-description}",
      "currency": "Rs. "
    },
    {
      "name": "flipkart",
      "enabled": true,
      "url": "${FLIPKART_FEED_URL:-}",
