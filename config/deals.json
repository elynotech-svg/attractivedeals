      "price_field": "${FLIPKART_PRICE_FIELD:-price}",
      "original_price_field": "${FLIPKART_ORIGINAL_PRICE_FIELD:-original_price}",
      "discount_percent_field": "${FLIPKART_DISCOUNT_PERCENT_FIELD:-discount_percent}",
      "coupon_field": "${FLIPKART_COUPON_FIELD:-coupon}",
      "category_field": "${FLIPKART_CATEGORY_FIELD:-category}",
      "description_field": "${FLIPKART_DESCRIPTION_FIELD:-description}",
      "currency": "Rs. "
    },
