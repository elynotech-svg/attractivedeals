{
  "_notes": [
    "Simplest Cuelinks mode: paste normal product/deal URLs below and set CUELINKS_CHANNEL_ID. The script wraps URLs through linksredirect.com before posting.",
    "You can get your Cuelinks Channel ID from Cuelinks dashboard > Account > My Channels. You do not need merchant feed/API URLs for this mode.",
    "Replace the sample deals with real products you want to share."
  ],
  "feeds": [
    {
      "name": "manual-cuelinks-deals",
      "type": "manual",
      "items": [
        {
          "title": "Sample Flipkart deal 40% off",
          "url": "https://www.flipkart.com/",
          "price": "599",
          "original_price": "999",
          "coupon": "CHECK APP",
          "category": "Shopping",
          "description": "Replace this sample with a real deal URL."
        },
        {
          "title": "Sample Ajio deal 50% off",
          "url": "https://www.ajio.com/",
          "price": "999",
          "original_price": "1999",
          "category": "Fashion",
          "description": "Replace this sample with a real deal URL."
        }
      ],
      "currency": "Rs. "
    }
  ],
  "affiliate": {
    "enabled": true,
    "network": "cuelinks",
    "channel_id_env": "CUELINKS_CHANNEL_ID",
    "source": "linkkit",
    "required": true
  },
  "filters": {
    "min_discount_percent": 20,
    "min_savings_amount": 0,
    "require_discount_data": true,
    "blocked_keywords": [
      "refurbished",
      "used",
      "renewed",
      "expired",
      "out of stock"
    ],
    "required_keywords": [],
    "max_items": 10
  },
  "hashtags": [
    "#deals",
    "#offers",
    "#shopping"
  ],
  "telegram": {
    "enabled": true,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_id_env": "TELEGRAM_CHAT_ID",
    "disable_web_page_preview": false,
    "timeout_seconds": 15,
    "required": false
  },
  "whatsapp": {
    "output_file": "out/whatsapp_deals.txt"
  }
}
